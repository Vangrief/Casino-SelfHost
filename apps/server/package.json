{
  "name": "@casino/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "db:migrate": "node-pg-migrate up --migration-file-language ts --tsconfig tsconfig.json",
    "db:migrate:down": "node-pg-migrate down --migration-file-language ts --tsconfig tsconfig.json"
  },
  "dependencies": {
    "@casino/shared": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "socket.io": "^4.8.0",
    "pg": "^8.13.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "node-pg-migrate": "^7.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0"
  }
}
